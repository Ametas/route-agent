# Port the agent listens on (default: 8081)
PORT=8081

# Host to bind the server to (default: 0.0.0.0)
HOST=0.0.0.0

# Secret key required in the 'x-orchestrator-secret' header for auth
EGRESS_CONTROL_SECRET=your_super_secure_secret_token_here

# Path to the sing-box configuration file (default: /etc/sing-box/config.json)
SINGBOX_CONFIG_PATH=/etc/sing-box/config.json

# Command to reload sing-box after configuration updates (default: systemctl reload sing-box)
RELOAD_COMMAND=systemctl reload sing-box
