# Port the agent listens on (default: 8081)
PORT=8081

# Host to bind the server to (default: 0.0.0.0)
HOST=0.0.0.0

# Secret key required in the 'x-orchestrator-secret' header/metadata for auth
EGRESS_CONTROL_SECRET=your_super_secure_secret_token_here

# Binary & Config paths
SINGBOX_CONFIG_PATH=/etc/sing-box/config.json
SINGBOX_BINARY_PATH=/usr/local/bin/sing-box
RELOAD_COMMAND=systemctl reload sing-box
CADDYFILE_PATH=/etc/caddy/Caddyfile
CADDY_RELOAD_COMMAND=systemctl reload caddy
OLCRTC_BINARY_PATH=/usr/local/bin/olcrtc
OLCRTC_MANAGER_BINARY_PATH=/usr/local/bin/olcrtc-manager
